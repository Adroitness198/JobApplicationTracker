@page
@model RegisterModel


<h1>@ViewData["Title"]</h1>

<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="login-card p-5">
        <h3 class="text-center mb-4 text-white">Create Account</h3>

        <form method="post">
            <!-- Email -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control custom-input" placeholder="Email" />
                <label>Email</label>
                <span asp-validation-for="Input.Email" class="text-warning"></span>
            </div>

            <!-- Password -->
            <div class="form-floating mb-3">
                <input asp-for="Input.Password" type="password" class="form-control custom-input" placeholder="Password" />
                <label>Password</label>
                <span asp-validation-for="Input.Password" class="text-warning"></span>
            </div>

            <!-- Confirm Password -->
            <div class="form-floating mb-3">
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control custom-input" placeholder="Confirm Password" />
                <label>Confirm Password</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-warning"></span>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn btn-primary w-100 py-2">Register</button>

            <!-- Links -->
            <div class="text-center mt-3">
                <a asp-page="./Login" class="text-info">Already have an account? Login</a>
            </div>
        </form>
    </div>
</div>