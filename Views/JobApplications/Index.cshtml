@using X.PagedList.Mvc.Core
@using JobApplicationTracker.Models

@model X.PagedList.IPagedList<JobApplication>

@{
    ViewData["Title"] = "My Applications";
}

<h2 class="mb-4 text-center">My Applications</h2>
<form method="get" asp-action="Index">
    <div class="d-flex mb-4 gap-2 flex-wrap justify-content-center">

        <input id="searchInput"
               name="searchString"
               type="text"
               placeholder="Search company"
               class="form-control w-auto" />

        <select id="statusFilter"
                name="statusFilter"
                class="form-select w-auto">
            <option value="">All Status</option>
            <option>Applied</option>
            <option>Interview</option>
            <option>Offer</option>
            <option>Rejected</option>
        </select>

        <button type="submit" class="btn btn-primary">
            Search
        </button>

    </div>
</form>

<p class="text-center">
    <a asp-action="Create" class="btn btn-success">Create New Application</a>
</p>

<!-- APPLICATION CARDS -->
<div class="row g-3" id="applicationsContainer">
    @foreach (var item in Model)
    {
        <div class="col-md-4 col-sm-6 app-card-container" data-company="@item.CompanyName.ToLower()" data-status="@item.Status.ToLower()">
            <div class="card app-card h-100 p-3 animate-card">

                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">@item.CompanyName</h5>
                    <span class="badge status-@item.Status.ToLower()">@item.Status</span>
                </div>

                <p class="mb-1"><strong>Role:</strong> @item.Role</p>
                <p class="mb-1"><strong>Date Applied:</strong> @item.DateApplied.ToShortDateString()</p>

                @if (item.InterviewDate != null)
                {
                    <p class="mb-1"><strong>Interview:</strong> @item.InterviewDate?.ToShortDateString()</p>
                }

                @if (item.ResumePath != null)
                {
                    <a href="@item.ResumePath" target="_blank" class="btn btn-sm btn-outline-primary mb-2">View Resume</a>
                }

                <div class="d-flex justify-content-between mt-2">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    <button class="btn btn-danger" onclick="openDeleteModal(@item.Id)">
                        Delete
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<!-- PAGINATION -->
<div class="mt-4 text-center">
    @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), new X.PagedList.Mvc.Core.PagedListRenderOptions
    {
        LiElementClasses = new[] { "page-item" },
        PageClasses = new[] { "page-link" },
        UlElementClasses = new[] { "pagination justify-content-center" }
        })
</div>

<div>
    @Html.PagedListPager(Model, page => Url.Action("Index", new
        {
        page,
        searchString = ViewData["CurrentFilter"] ?? "",
        statusFilter = ViewData["CurrentStatusFilter"] ?? ""
        }))
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <form id="deleteForm" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    Are you sure you want to delete this application?
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-danger">
                        Delete
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<script>
    function openDeleteModal(id) {
        document.getElementById("deleteForm").action = "/JobApplications/Delete/" + id;
        var modal = new bootstrap.Modal(document.getElementById("deleteModal"));
        modal.show();
    }

    document.addEventListener("DOMContentLoaded", function () {

        const searchInput = document.getElementById("searchInput");
        const statusFilter = document.getElementById("statusFilter");
        const appCards = document.querySelectorAll(".app-card-container");

        function filterApps() {
            const searchText = searchInput.value.toLowerCase();
            const statusText = statusFilter.value.toLowerCase();

            appCards.forEach(card => {
                const company = card.dataset.company;
                const status = card.dataset.status;

                const matchesSearch = company.includes(searchText);
                const matchesStatus = !statusText || status === statusText;

                if (matchesSearch && matchesStatus) {
                    card.classList.remove("hide");
                } else {
                    card.classList.add("hide");
                }
            });
        }

        searchInput.addEventListener("input", filterApps);
        statusFilter.addEventListener("change", filterApps);

    });
</script>