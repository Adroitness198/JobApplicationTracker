@{
    ViewData["Title"] = "Dashboard";
}

<h2>Dashboard</h2>

<div class="row mt-4">
    <div class="col-md-3"><strong>Total:</strong> @ViewBag.Total</div>
    <div class="col-md-3"><strong>Applied:</strong> @ViewBag.Applied</div>
    <div class="col-md-3"><strong>Interview:</strong> @ViewBag.Interview</div>
    <div class="col-md-3"><strong>Offers:</strong> @ViewBag.Offer</div>
</div>
